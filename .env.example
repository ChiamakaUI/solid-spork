# Yellowstone gRPC (free token: https://www.allnodes.com/publicnode — or SolInfra credits)
GRPC_ENDPOINT=https://solana-yellowstone-grpc.publicnode.com:443
GRPC_X_TOKEN=

# Standard Solana JSON-RPC
RPC_URL=https://api.mainnet-beta.solana.com

# Payer keypair (JSON byte array). NEVER commit the real file.
KEYPAIR_PATH=./payer.keypair.json
# Inline keypair for hosts without a file (e.g. Railway): paste the SAME JSON byte
# array as a single-line value. Takes precedence over KEYPAIR_PATH. Keep it secret.
KEYPAIR_JSON=

# Shared secret guarding POST /campaign/start (the SOL-spending route). Without it
# the launch endpoint is DISABLED. Required to run the control console anywhere public.
# Locally: set any value here AND enter the same token in the dashboard's Start button.
CONTROL_TOKEN=

# Server port. Railway and most hosts inject PORT automatically — leave unset there.
# DASHBOARD_PORT=8088

# Claude API for the retry agent (mock mode if unset — dev only). Put the REAL
# key in .env (gitignored), NEVER here in .env.example (committed).
ANTHROPIC_API_KEY=
# Haiku 4.5: cheapest capable ($1/$5 per MTok), the default. Set claude-sonnet-4-6
# ($3/$15) for richer reasoning — agent fires only on failures, so either costs cents.
AGENT_MODEL=claude-haiku-4-5
